# Machine-specific settings for the Makefile.
# Copy to config.mk and edit for your environment.
# config.mk is gitignored — never commit it.

# K3s kubeconfig path
KUBECONFIG ?= /etc/rancher/k3s/k3s.yaml

# K3s node name (used for nodeSelector in Helm)
K3S_NODE ?= nodal

# Whether sudo is needed for containerd image import
# Set to empty string if your user can access the containerd socket directly
SUDO_CTR ?= sudo

# Lifecycle mode:
#   auto        = use REGISTRY_HOST when set; otherwise single-node unless a
#                 multi-node cluster is detected
#   single-node = import runtime images directly into local K3s containerd
#   multi-node  = push NodalArc runtime images to REGISTRY_HOST
MODE ?= auto

# Default session for `make session`
DEFAULT_SESSION ?= configs/sessions/earth-leo-walker.yaml

# Extra Helm arguments for non-image chart values.
# Runtime image values are generated from scripts/na-images.sh. Do not put
# images.*, imagePullPolicy, or buildTag overrides here unless explicitly
# running with ALLOW_IMAGE_ARG_OVERRIDE=1 for diagnostics.
HELM_EXTRA_ARGS ?=

# --- Multi-node setup ---
# REGISTRY_HOST is the hostname:port Kubernetes nodes pull from.
# REGISTRY_PREFIX is derived by the Makefile; do not set it independently.
#
# Empty REGISTRY_HOST means single-node direct import.
# Non-empty REGISTRY_HOST means registry-backed image distribution.
# scripts/detect-registry.sh is used as a fallback when REGISTRY_HOST is empty
# and /etc/rancher/k3s/registries.yaml declares a registry mirror.
#
# Example:
#
# REGISTRY_HOST ?= node01:5000
