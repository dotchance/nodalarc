hostname {{ hostname }}
log file /var/log/frr/isisd.log informational

{# system_id is a resolver-owned globally-unique identity fact supplied by
   the producer and consumed verbatim. plane/slot restart per segment and
   must never be encoded into identity. #}

{# Timer and BFD values are resolver-owned per-domain facts supplied by the
   producer (routing.domains[].timers); the template carries no fallbacks. #}
router isis NODAL
 net {{ area_id }}.{{ system_id }}.00
 is-type level-1-2
 metric-style wide
{% if sr_enabled | default(false) %}
 segment-routing on
 segment-routing global-block {{ srgb_start }} {{ srgb_end }} local-block 40000 49999
 segment-routing prefix {{ ipv4_loopback }}/32 index {{ node_sid_index }}
{% endif %}
{% if redistribute_static %}
 redistribute ipv4 static level-2
{% endif %}
 lsp-gen-interval 1
 spf-delay-ietf init-delay {{ spf_init_delay }} short-delay {{ spf_short_delay }} long-delay {{ spf_long_delay }} holddown {{ spf_holddown }} time-to-learn {{ spf_time_to_learn }}
 max-lsp-lifetime 1200
 lsp-refresh-interval 150
exit

{% for iface_name, info in interface_info.items() %}
{% if not info.static_only %}
interface {{ iface_name }}
 ip router isis NODAL
 isis network point-to-point
 isis metric {{ (reference_bandwidth / info.bandwidth_mbps) | int }}
 isis hello-interval {{ isis_hello_interval }}
 isis hello-multiplier {{ isis_hello_multiplier }}
{% if bfd_enabled %}
 isis bfd
{% endif %}
exit
{% endif %}
{% endfor %}

{% for iface in gnd_interfaces %}
interface {{ iface }}
 ip router isis NODAL
 isis network point-to-point
 isis metric 10
 isis hello-interval {{ isis_hello_interval }}
 isis hello-multiplier {{ isis_hello_multiplier }}
{% if bfd_enabled %}
 isis bfd
{% endif %}
exit
{% endfor %}

interface lo
 ip router isis NODAL
 isis passive
exit

{% if node_type == "ground_station" and terr0_igp_enabled %}
interface terr0
 ip router isis NODAL
{% if not terr0_igp_active %}
 isis passive
{% endif %}
 isis metric {{ terr0_metric }}
exit
{% endif %}

{% if node_type == "ground_station" and terr0_default_route %}
router isis NODAL
 default-information originate ipv4 level-2 always metric {{ terr0_default_metric }}
exit
{% endif %}
