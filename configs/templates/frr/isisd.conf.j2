hostname {{ hostname }}
log file /var/log/frr/isisd.log informational

{% if node_type == "satellite" %}
{# System-ID for satellites: plane and slot encoded as hex #}
{% set system_id = "%04x.%04x.0001" | format(plane, slot) %}
{% set sid_index = plane * 100 + slot + 1 %}
{% elif node_type == "ground_station" %}
{# System-ID for ground stations: 00ff prefix with gs_index #}
{% set system_id = "00ff.%04x.0002" | format(gs_index) %}
{% set sid_index = gs_sid_offset + gs_index %}
{% endif %}

router isis NODAL
 net {{ area_id }}.{{ system_id }}.00
 is-type level-1-2
 metric-style wide
{% if sr_enabled | default(false) %}
 segment-routing on
 segment-routing global-block {{ srgb_start }} {{ srgb_end }} local-block 40000 49999
 segment-routing prefix {{ ipv4_loopback }}/32 index {{ sid_index }}
{% endif %}
 lsp-gen-interval 1
 spf-interval 50
 max-lsp-lifetime 1200
 lsp-refresh-interval 150
exit

{% for iface_name, info in interface_info.items() %}
interface {{ iface_name }}
 ip router isis NODAL
 isis network point-to-point
 isis metric {{ (reference_bandwidth / info.bandwidth_mbps) | int }}
 isis hello-interval 1
 isis hello-multiplier 3
exit
{% endfor %}

{% for iface in gnd_interfaces %}
interface {{ iface }}
 ip router isis NODAL
 isis network point-to-point
 isis metric 10
 isis hello-interval 1
 isis hello-multiplier 3
exit
{% endfor %}

interface lo
 ip router isis NODAL
 isis passive
exit

{% if node_type == "ground_station" and terrestrial_prefixes is defined %}
interface terr0
 ip router isis NODAL
 isis passive
 isis metric {{ terr0_metric | default(10) }}
exit
{% endif %}

{% if node_type == "ground_station" and terr0_default_route | default(false) %}
router isis NODAL
 default-information originate ipv4 level-2 always metric {{ terr0_default_metric | default(100) }}
exit
{% endif %}
