hostname {{ hostname }}
log file /var/log/frr/ospfd.log informational

{# Timer and BFD values are resolver-owned per-domain facts supplied by the
   producer (routing.domains[].timers); the template carries no fallbacks. #}

router ospf
{% if redistribute_static %}
 redistribute static
{% endif %}
 ospf router-id {{ ipv4_loopback }}
{% if te_enabled | default(false) %}
 mpls-te on
 mpls-te router-address {{ ipv4_loopback }}
{% endif %}
 timers throttle spf {{ ospf_spf_delay }} {{ ospf_spf_initial_hold }} {{ ospf_spf_max_hold }}
exit

interface lo
 ip ospf area {{ area_id }}
 ip ospf passive
exit

{% for iface_name, info in interface_info.items() %}
{% if not info.static_only %}
interface {{ iface_name }}
{% if info.cross_area %}
 ip ospf area 0.0.0.0
{% else %}
 ip ospf area {{ area_id }}
{% endif %}
 ip ospf network point-to-point
 ip ospf cost {{ (reference_bandwidth / info.bandwidth_mbps) | int }}
 ip ospf hello-interval {{ ospf_hello_interval }}
 ip ospf dead-interval {{ ospf_dead_interval }}
{% if bfd_enabled %}
 ip ospf bfd
{% endif %}
exit
{% endif %}
{% endfor %}

{% for iface in gnd_interfaces %}
interface {{ iface }}
 ip ospf area 0.0.0.0
 ip ospf network point-to-point
 ip ospf cost 10
 ip ospf hello-interval {{ ospf_hello_interval }}
 ip ospf dead-interval {{ ospf_dead_interval }}
{% if bfd_enabled %}
 ip ospf bfd
{% endif %}
exit
{% endfor %}

{% if node_type == "ground_station" and terr0_igp_enabled %}
interface terr0
 ip ospf area {{ area_id }}
 ip ospf passive
exit
{% endif %}

{% if node_type == "ground_station" and terr0_default_route %}
router ospf
 default-information originate always metric {{ terr0_default_metric }}
exit
{% endif %}
