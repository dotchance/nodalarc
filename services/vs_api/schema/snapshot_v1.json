{
  "$defs": {
    "ActiveFlow": {
      "description": "Active traffic flow configuration.",
      "properties": {
        "flow_id": {
          "title": "Flow Id",
          "type": "string"
        },
        "src_node": {
          "title": "Src Node",
          "type": "string"
        },
        "dst_node": {
          "title": "Dst Node",
          "type": "string"
        },
        "protocol": {
          "title": "Protocol",
          "type": "string"
        },
        "probe_type": {
          "title": "Probe Type",
          "type": "string"
        }
      },
      "required": [
        "flow_id",
        "src_node",
        "dst_node",
        "protocol",
        "probe_type"
      ],
      "title": "ActiveFlow",
      "type": "object"
    },
    "ActuationHealth": {
      "description": "Session-level Scheduler actuation health.",
      "properties": {
        "session_id": {
          "title": "Session Id",
          "type": "string"
        },
        "wiring_generation": {
          "title": "Wiring Generation",
          "type": "string"
        },
        "scheduler_instances": {
          "items": {
            "$ref": "#/$defs/ActuationHealthInstance"
          },
          "title": "Scheduler Instances",
          "type": "array"
        }
      },
      "required": [
        "session_id",
        "wiring_generation"
      ],
      "title": "ActuationHealth",
      "type": "object"
    },
    "ActuationHealthGroundStation": {
      "description": "Latest actuation state for one GS on one Scheduler instance.",
      "properties": {
        "gs_id": {
          "title": "Gs Id",
          "type": "string"
        },
        "actuation_state": {
          "title": "Actuation State",
          "type": "string"
        },
        "since": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Since"
        },
        "reason_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reason Code"
        },
        "blocking_new_ground_link_up": {
          "title": "Blocking New Ground Link Up",
          "type": "boolean"
        },
        "recovery_status": {
          "additionalProperties": true,
          "title": "Recovery Status",
          "type": "object"
        },
        "last_event": {
          "additionalProperties": true,
          "title": "Last Event",
          "type": "object"
        }
      },
      "required": [
        "gs_id",
        "actuation_state",
        "blocking_new_ground_link_up"
      ],
      "title": "ActuationHealthGroundStation",
      "type": "object"
    },
    "ActuationHealthInstance": {
      "description": "Aggregated actuation health for one Scheduler instance.",
      "properties": {
        "scheduler_instance_id": {
          "title": "Scheduler Instance Id",
          "type": "string"
        },
        "hostname": {
          "title": "Hostname",
          "type": "string"
        },
        "status": {
          "title": "Status",
          "type": "string"
        },
        "ground_stations": {
          "items": {
            "$ref": "#/$defs/ActuationHealthGroundStation"
          },
          "title": "Ground Stations",
          "type": "array"
        }
      },
      "required": [
        "scheduler_instance_id",
        "hostname",
        "status"
      ],
      "title": "ActuationHealthInstance",
      "type": "object"
    },
    "ActuationNotice": {
      "description": "User-visible Scheduler actuation problem for one ground station.",
      "properties": {
        "gs_id": {
          "title": "Gs Id",
          "type": "string"
        },
        "actuation_state": {
          "title": "Actuation State",
          "type": "string"
        },
        "reason_code": {
          "title": "Reason Code",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "since": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Since"
        },
        "blocking_new_ground_link_up": {
          "title": "Blocking New Ground Link Up",
          "type": "boolean"
        },
        "affected_pairs": {
          "items": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "title": "Affected Pairs",
          "type": "array"
        },
        "desired_pairs_for_gs": {
          "items": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "title": "Desired Pairs For Gs",
          "type": "array"
        },
        "actual_pairs_for_gs": {
          "items": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "title": "Actual Pairs For Gs",
          "type": "array"
        },
        "ome_visible_scheduled_pairs_for_gs": {
          "items": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "title": "Ome Visible Scheduled Pairs For Gs",
          "type": "array"
        },
        "recovery_status": {
          "additionalProperties": true,
          "title": "Recovery Status",
          "type": "object"
        },
        "last_event": {
          "additionalProperties": true,
          "title": "Last Event",
          "type": "object"
        }
      },
      "required": [
        "gs_id",
        "actuation_state",
        "reason_code",
        "message",
        "blocking_new_ground_link_up"
      ],
      "title": "ActuationNotice",
      "type": "object"
    },
    "LinkState": {
      "description": "State of a single link between two nodes.",
      "properties": {
        "node_a": {
          "title": "Node A",
          "type": "string"
        },
        "node_b": {
          "title": "Node B",
          "type": "string"
        },
        "state": {
          "title": "State",
          "type": "string"
        },
        "link_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Link Type"
        },
        "link_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Link Reason"
        },
        "latency_ms": {
          "title": "Latency Ms",
          "type": "number"
        },
        "bandwidth_mbps": {
          "title": "Bandwidth Mbps",
          "type": "number"
        },
        "range_km": {
          "title": "Range Km",
          "type": "number"
        },
        "traffic_load_pct": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Traffic Load Pct"
        },
        "interface_a": {
          "default": "",
          "title": "Interface A",
          "type": "string"
        },
        "interface_b": {
          "default": "",
          "title": "Interface B",
          "type": "string"
        }
      },
      "required": [
        "node_a",
        "node_b",
        "state",
        "link_type",
        "link_reason",
        "latency_ms",
        "bandwidth_mbps",
        "range_km",
        "traffic_load_pct"
      ],
      "title": "LinkState",
      "type": "object"
    },
    "NetworkHealth": {
      "description": "Overall network health status.",
      "properties": {
        "status": {
          "title": "Status",
          "type": "string"
        },
        "converging_since_ms": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Converging Since Ms"
        },
        "unreachable_flows": {
          "title": "Unreachable Flows",
          "type": "integer"
        },
        "last_convergence_ms": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Last Convergence Ms"
        }
      },
      "required": [
        "status",
        "converging_since_ms",
        "unreachable_flows",
        "last_convergence_ms"
      ],
      "title": "NetworkHealth",
      "type": "object"
    },
    "NodeState": {
      "description": "State of a single node in the constellation.",
      "properties": {
        "node_id": {
          "title": "Node Id",
          "type": "string"
        },
        "node_type": {
          "title": "Node Type",
          "type": "string"
        },
        "lat_deg": {
          "title": "Lat Deg",
          "type": "number"
        },
        "lon_deg": {
          "title": "Lon Deg",
          "type": "number"
        },
        "alt_km": {
          "title": "Alt Km",
          "type": "number"
        },
        "vel_x_km_s": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Vel X Km S"
        },
        "vel_y_km_s": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Vel Y Km S"
        },
        "vel_z_km_s": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Vel Z Km S"
        },
        "plane": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Plane"
        },
        "slot": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Slot"
        },
        "routing_area": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Routing Area"
        },
        "neighbor_count": {
          "default": 0,
          "title": "Neighbor Count",
          "type": "integer"
        },
        "isl_count": {
          "default": 0,
          "title": "Isl Count",
          "type": "integer"
        },
        "gnd_count": {
          "default": 0,
          "title": "Gnd Count",
          "type": "integer"
        },
        "prefix": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prefix"
        },
        "min_elevation_deg": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Min Elevation Deg"
        },
        "beam_falloff_exponent": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Beam Falloff Exponent"
        }
      },
      "required": [
        "node_id",
        "node_type",
        "lat_deg",
        "lon_deg",
        "alt_km",
        "vel_x_km_s",
        "vel_y_km_s",
        "vel_z_km_s",
        "plane",
        "slot"
      ],
      "title": "NodeState",
      "type": "object"
    },
    "RecentEvent": {
      "description": "Recent event for the VF event log.",
      "properties": {
        "sim_time": {
          "format": "date-time",
          "title": "Sim Time",
          "type": "string"
        },
        "node_id": {
          "title": "Node Id",
          "type": "string"
        },
        "event_type": {
          "title": "Event Type",
          "type": "string"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "sim_time",
        "node_id",
        "event_type",
        "summary"
      ],
      "title": "RecentEvent",
      "type": "object"
    },
    "TracedPath": {
      "description": "Forwarding path trace for a traffic flow.",
      "properties": {
        "flow_id": {
          "title": "Flow Id",
          "type": "string"
        },
        "src_node": {
          "title": "Src Node",
          "type": "string"
        },
        "dst_node": {
          "title": "Dst Node",
          "type": "string"
        },
        "hops": {
          "items": {
            "type": "string"
          },
          "title": "Hops",
          "type": "array"
        },
        "reverse_hops": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Reverse Hops",
          "type": "array"
        },
        "hop_rtts": {
          "default": [],
          "items": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ]
          },
          "title": "Hop Rtts",
          "type": "array"
        },
        "reverse_hop_rtts": {
          "default": [],
          "items": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ]
          },
          "title": "Reverse Hop Rtts",
          "type": "array"
        },
        "rtt_ms": {
          "default": 0.0,
          "title": "Rtt Ms",
          "type": "number"
        },
        "reverse_rtt_ms": {
          "default": 0.0,
          "title": "Reverse Rtt Ms",
          "type": "number"
        },
        "asymmetry_detected": {
          "default": false,
          "title": "Asymmetry Detected",
          "type": "boolean"
        },
        "method": {
          "default": "tracepath",
          "title": "Method",
          "type": "string"
        },
        "path_valid_until": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path Valid Until"
        },
        "path_valid_seconds": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path Valid Seconds"
        },
        "traced_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Traced At"
        }
      },
      "required": [
        "flow_id",
        "src_node",
        "dst_node",
        "hops"
      ],
      "title": "TracedPath",
      "type": "object"
    }
  },
  "description": "Complete constellation state sent via WebSocket at ~1Hz.\n\nFull snapshots only \u2014 no deltas. Drop intermediate frames\nif behind, never queue.",
  "properties": {
    "sim_time": {
      "format": "date-time",
      "title": "Sim Time",
      "type": "string"
    },
    "wall_time": {
      "format": "date-time",
      "title": "Wall Time",
      "type": "string"
    },
    "schema_version": {
      "title": "Schema Version",
      "type": "integer"
    },
    "session_id": {
      "title": "Session Id",
      "type": "string"
    },
    "nodes": {
      "items": {
        "$ref": "#/$defs/NodeState"
      },
      "title": "Nodes",
      "type": "array"
    },
    "links": {
      "items": {
        "$ref": "#/$defs/LinkState"
      },
      "title": "Links",
      "type": "array"
    },
    "traced_paths": {
      "items": {
        "$ref": "#/$defs/TracedPath"
      },
      "title": "Traced Paths",
      "type": "array"
    },
    "active_flows": {
      "items": {
        "$ref": "#/$defs/ActiveFlow"
      },
      "title": "Active Flows",
      "type": "array"
    },
    "recent_events": {
      "items": {
        "$ref": "#/$defs/RecentEvent"
      },
      "title": "Recent Events",
      "type": "array"
    },
    "network_health": {
      "$ref": "#/$defs/NetworkHealth"
    },
    "routing_stack": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Routing Stack"
    },
    "constellation_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Constellation Name"
    },
    "session_status": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Session Status"
    },
    "session_status_detail": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Session Status Detail"
    },
    "playback_paused": {
      "default": false,
      "title": "Playback Paused",
      "type": "boolean"
    },
    "playback_speed": {
      "default": 1.0,
      "title": "Playback Speed",
      "type": "number"
    },
    "stale": {
      "default": false,
      "title": "Stale",
      "type": "boolean"
    },
    "actuation_notices": {
      "items": {
        "$ref": "#/$defs/ActuationNotice"
      },
      "title": "Actuation Notices",
      "type": "array"
    },
    "actuation_health": {
      "anyOf": [
        {
          "$ref": "#/$defs/ActuationHealth"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "sim_time",
    "wall_time",
    "schema_version",
    "session_id",
    "nodes",
    "links",
    "traced_paths",
    "active_flows",
    "recent_events",
    "network_health"
  ],
  "title": "StateSnapshot",
  "type": "object"
}
